# =================================================================
# Castorice Agent - 环境变量配置（API 密钥等敏感信息）
# 使用前请复制 .env.example 为 .env 并填入真实 API Key
# =================================================================

# --------------- 默认 LLM 提供商选择 ---------------
# 可选：openai / anthropic / ollama / openrouter
CASTORICE_LLM_PROVIDER=openai

# --------------- OpenAI / 兼容协议 ---------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --------------- Anthropic Claude ---------------
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --------------- Ollama 本地大模型 ---------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --------------- OpenRouter ---------------
# OPENROUTER_API_KEY=sk-or-your-openrouter-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --------------- Google Gemini ---------------
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-1.5-flash

# --------------- 阿里云通义千问 ---------------
# QWEN_API_KEY=your-qwen-api-key
# QWEN_MODEL=qwen-plus

# --------------- QQ 机器人（QQ 开放平台） ---------------
# QQ_BOT_APP_ID=your-qq-bot-app-id
# QQ_BOT_APP_SECRET=your-qq-bot-app-secret
# QQ_BOT_SANDBOX=true

# --------------- VRChat ---------------
# VRCHAT_USERNAME=your-vrchat-username
# VRCHAT_PASSWORD=your-vrchat-password

# --------------- 公共参数 ---------------
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
