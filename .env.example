# =================================================================
# Castorice Agent - 环境变量配置（API 密钥等敏感信息）
# 使用前请复制本文件为 .env 并填入真实值
# =================================================================

# --------------- 默认 LLM 提供商选择 ---------------
# 可选：openai / anthropic / ollama / openrouter
CASTORICE_LLM_PROVIDER=openai

# --------------- OpenAI / 兼容协议 (通用模板) ---------------
OPENAI_API_KEY=sk-your-real-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 百度千帆 Token Plan（OpenAI 协议兼容）
# 取消下面3行注释并填入真实 key 即可使用：
# OPENAI_API_KEY=你的百度千帆Token-Plan-key
# OPENAI_BASE_URL=https://qianfan.baidubce.com/v2/tokenplan/personal
# OPENAI_MODEL=deepseek-v4-pro

# 阿里云百炼（OpenAI 协议兼容）
# 取消下面3行注释并填入真实 key 即可使用：
# OPENAI_API_KEY=你的阿里云百炼key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# --------------- Anthropic Claude ---------------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --------------- Ollama 本地大模型 ---------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# --------------- OpenRouter ---------------
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --------------- 公共参数 ---------------
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60